{
    "name": "888jets/website",
    "description": "888Jets B2C Website powered by CodeIgniter 4",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "kint-php/kint": "^6.1",
        "phpunit/phpunit": "^10.5",
        "predis/predis": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "Config\\": "app/Config/",
            "App\\": "app/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/Support/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "codeigniter4/devkit": true
        }
    },
    "scripts": {
        "post-update-cmd": [
            "CodeIgniter\\ComposerScripts::postUpdate"
        ]
    }
}
